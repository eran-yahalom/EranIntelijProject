<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="e commerce Test Suite" parallel="tests" thread-count="3">
    <listeners>
<!--        <listener class-name="listeners.AnnotationTransformer"/>-->
        <listener class-name="listeners.TestNGListener"/>
        <listener class-name="listeners.ProgressListener"/>
        <listener class-name="utils.RetryListener"/>
    </listeners>

    <test name="e commerce tests">
        <classes>
            <class name="launchers.HeaderLauncher"/>
            <class name="launchers.PostmanAPILauncher"/>
            <class name="launchers.SwaggerAPILauncher"/>
            <class name="launchers.RegisterLauncher"/>
            <class name="launchers.LoginLauncher"/>
            <class name="launchers.BookLauncher"/>
            <class name="launchers.CartLauncher"/>
            <class name="launchers.FooterLauncher"/>
            <class name="launchers.BreadCrumbsLauncher"/>
        </classes>
    </test>
</suite>